{
  "name": "mini-news-portal-system",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "pnpm --dir e2e/playwright test",
    "db:generate": "pnpm --dir apps/web db:generate",
    "db:migrate": "pnpm --dir apps/web db:migrate",
    "db:seed": "pnpm --dir apps/web db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@eslint/js": "^9.27.0",
    "@eslint/markdown": "^6.5.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0"
    ,"husky": "^9.1.7"
    ,"prettier": "^3.5.3"
    ,"typescript": "^5.8.3"
    ,"vue-eslint-parser": "^10.1.4"
  }
}
